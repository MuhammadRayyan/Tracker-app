{
  "name": "habit-tracker",
  "version": "2.0.0",
  "description": "Habit Tracker - Build consistency, one day at a time",
  "main": "index.html",
  "scripts": {
    "build": "echo 'Static app - no build needed'",
    "cap:init": "npx cap init 'Habit Tracker' com.habits.tracker --web-dir public",
    "cap:add": "npx cap add android",
    "cap:copy": "npx cap copy android",
    "cap:open": "npx cap open android",
    "cap:sync": "npx cap sync android",
    "android": "npm run cap:copy && npx cap open android",
    "apk": "cd android && ./gradlew assembleDebug && echo 'APK at: android/app/build/outputs/apk/debug/app-debug.apk'"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "typescript": "^5.0.0"
  }
}
